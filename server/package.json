{
  "name": "sentiment-crawler-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx --env-file=.env src/index.ts",
    "crawl": "tsx --env-file=.env src/crawl-once.ts",
    "migrate": "tsx --env-file=.env src/migrate.ts",
    "prod": "cross-env NODE_ENV=production tsx src/index.ts --env-file=.env"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3"
  }
}
